  <rdf:type rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Hand_Conditions"/>
  <ICF-:description xml:lang="en">Using one or both hands to seize and hold something, such as when grasping a tool or a door knob.</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Grasping</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d4402">
