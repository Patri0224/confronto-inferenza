  <ICF-:description xml:lang="en">Engaging in temporary contacts and links with strangers for specific purposes, when asking for directions or other information, or making a purchase.</ICF-:description>
  <ICF-:descrizioneITA rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avere contatti e legami temporanei con estranei per scopi specifici, come quando sichiede unÃ¢â‚¬â„¢indicazione o si effettua un acquisto.</ICF-:descrizioneITA>
  <ICF-:nomeIta rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Entrare in relazione con estranei</ICF-:nomeIta>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relating with strangers</rdfs:label>
</owl:Class>

