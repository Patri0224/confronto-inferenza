<owl:ObjectProperty rdf:about="http://www.stiima.cnr.it/RientraOnt3#isEvaluatedForJob">
  <rdfs:domain rdf:resource="http://www.stiima.cnr.it/FOAF-excerpt#Person"/>
  <rdfs:range rdf:resource="http://www.stiima.cnr.it/JobList#Job"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Connects a person to a profession for which the person's health condition is being evaluated.</rdfs:comment>
