  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#b164"/>
  <ICF-:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mental functions of identifying, analysing, and integrating incongruent or conflicting information into a solution.</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Problem Solving</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#b1648">
