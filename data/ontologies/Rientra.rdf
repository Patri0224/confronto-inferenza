  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#d355"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Activities_and_participation"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Hearing_Loss"/>
  <ICF-:description xml:lang="en">Starting, sustaining and ending an examination of a matter, with arguments for or against, or debate carried out by means of spoken, written, sign or other forms of language, with one or more people one knows or who are strangers, in formal or casual settings.

Inclusions: discussion with one person or many people</ICF-:description>
  <ICF-:descrizioneITA rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Avviare, mantenere e terminare lÃ¢â‚¬â„¢esame di una questione, fornendo argomenti a favore o contro, o un dibattito realizzato attraverso linguaggio verbale, scritto, dei segni o altre forme di linguaggio, con una o piÃƒÂ¹ persone conosciute o meno, in contesti formali o informali.

Inclusione: discussione con una o molte persone</ICF-:descrizioneITA>
  <ICF-:nomeIta rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Discussione</ICF-:nomeIta>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Discussion</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d3550">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#d355"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#d3550"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#d355"/>
  <ICF-:description xml:lang="en">Initiating, maintaining, shaping or terminating an argument or debate with one person.</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Discussion with one person</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d3551">
