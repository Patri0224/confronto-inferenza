  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#d410"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Spinal_Cord_Injury"/>
  <ICF-:description xml:lang="en">Getting into and out of a seated position and changing body position from sitting down to any other position, such as standing up or lying down.

Inclusions: getting into a sitting position with bent legs or cross-legged; getting into a sitting position with feet supported or unsupported</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sitting</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d4104">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Spinal_Cord_Injury"/>
