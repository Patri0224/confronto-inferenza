  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#d3300"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#d330"/>
  <ICF-:description xml:lang="en">Using single words to label objects, persons or actions such as ball, mommy, bye-bye.</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Producing meaningful sounds</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d3301">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#d330"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#d3301"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#d330"/>
  <ICF-:description xml:lang="en">Using words to produce simple spoken messages such as single or few words or expressing a need (e.g. I want ...) or feeling (e.g., I like ...).</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Producing simple spoken messages</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d3302">
