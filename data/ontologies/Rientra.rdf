  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#d410"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Spinal_Cord_Injury"/>
  <ICF-:description xml:lang="en">Adjusting or moving the weight of the body from one position to another while sitting, standing or lying, such as moving from one foot to another while standing.

Exclusions: transferring oneself (d420); walking (d450)</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Shifting the body's centre of gravity</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d415">
