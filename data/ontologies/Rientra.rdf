  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#b1641"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#b164"/>
  <ICF-:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mental functions of coordinating parts into a whole, of systematizing; the mental function involved in developing a method of proceeding or acting.</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Organization and planning</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#b1642">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#b164"/>
