  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#ICF_Core_set"/>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#b1261">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#b126"/>
