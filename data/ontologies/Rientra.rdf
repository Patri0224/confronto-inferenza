  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Simple calculation</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#b1721">
