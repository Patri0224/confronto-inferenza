  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Stroke"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Traumatic_Brain_Injury"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Vocational_Rehabilitation"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Hand_Conditions"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Low_Back_Pain"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Muskoloskeletal_Conditions_for_Post_Acute_Care"/>
  <ICF-:description xml:lang="en">Carrying out the coordinated actions and tasks of putting on and taking off clothes and footwear in sequence and in keeping with climatic and social conditions, such as by putting on, adjusting and removing shirts, skirts, blouses, pants, undergarments, saris, kimono, tights, hats, gloves, coats, shoes, boots, sandals and slippers.

Inclusions: putting on or taking off clothes and footwear and choosing appropriate clothing</ICF-:description>
  <ICF-:descrizioneITA rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eseguire le azioni coordinate e i compiti del mettersi e togliersi indumenti e calzature in sequenza e in accordo con le condizioni climatiche e sociali, come nellÃ¢â‚¬â„¢indossare, sistemarsi e togliersi camicie, gonne, camicette, pantaloni, biancheria intima, sari, kimono, calze, cappelli, guanti, cappotti, scarpe,
stivali, sandali e ciabatte.

Inclusioni: mettersi e togliersi indumenti e calzature e scegliere lÃ¢â‚¬â„¢abbigliamento appropriato</ICF-:descrizioneITA>
  <ICF-:nomeIta rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vestirsi</ICF-:nomeIta>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dressing</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d550">
