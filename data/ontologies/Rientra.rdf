<owl:Class rdf:about="http://www.stiima.cnr.it/JobList#Job">
  <owl:equivalentClass>
    <owl:Restriction>
      <owl:onProperty rdf:resource="http://www.stiima.cnr.it/JobList#requires"/>
      <owl:onClass rdf:resource="http://www.stiima.cnr.it/JobList#Job_Descriptor"/>
      <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
    </owl:Restriction>
  </owl:equivalentClass>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/JobList#Job_Descriptor">
  <owl:equivalentClass>
    <owl:Restriction>
      <owl:onProperty rdf:resource="http://www.stiima.cnr.it/JobList#concerns"/>
      <owl:onClass>
        <owl:Class>
          <owl:unionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://www.stiima.cnr.it/SkAb#Abilities"/>
            <rdf:Description rdf:about="http://www.stiima.cnr.it/SkAb#Skills"/>
          </owl:unionOf>
        </owl:Class>
      </owl:onClass>
      <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
    </owl:Restriction>
  </owl:equivalentClass>
  <owl:equivalentClass>
    <owl:Restriction>
      <owl:onProperty rdf:resource="http://www.stiima.cnr.it/JobList#hasScore"/>
      <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
    </owl:Restriction>
  </owl:equivalentClass>
</owl:Class>

