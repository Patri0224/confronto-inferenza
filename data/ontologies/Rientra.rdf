  <rdf:type rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Hand_Conditions"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Hearing_Loss"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Low_Back_Pain"/>
  <ICF-:description xml:lang="en">Selecting, procuring and transporting all goods and services required for daily living, such as selecting, procuring, transporting and storing food, drink, clothing, cleaning materials, fuel, household items, utensils, cooking ware, play and recreational materials, domestic appliances and tools; procuring utilities and other household services.

Inclusions: shopping and gathering daily necessities

Exclusions: acquiring a place to live (d610)</ICF-:description>
  <ICF-:descrizioneITA rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Scegliere, procurarsi e trasportare tutti i beni e i servizi necessari per la vita quotidiana, come scegliere, procurarsi, trasportare e riporre cibo, bevande, vestiario, materiali per la pulizia, combustibile, articoli per la casa, utensili, padellame, utensili domestici e attrezzi; procurarsi comoditÃƒ  e altre cose utili per la casa.

Inclusioni: comprare e procurarsi ciÃƒÂ² che serve quotidianamente

Esclusione: procurarsi un posto in cui vivere (d610)</ICF-:descrizioneITA>
  <ICF-:nomeIta rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Procurarsi beni e servizi</ICF-:nomeIta>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acquisition of goods and services</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d630">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Activities_and_participation"/>
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Spinal_Cord_Injury"/>
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Stroke"/>
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Traumatic_Brain_Injury"/>
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Hand_Conditions"/>
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Low_Back_Pain"/>
