  <ICF-:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sensory functions relating to sensing the presence of sounds.</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sound detection</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#b2301">
