  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#b1645"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#b164"/>
  <ICF-:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mental functions involved in discriminating between and evaluating different options, such as those involved in forming an opinion.</ICF-:description>
