  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#b280"/>
  <ICF-:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Unpleasant sensation indicating potential or actual damage to some body structure located in areas of skin served by the same nerve root.</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Radiating pain in a dermatome</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#b2804">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#b280"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
