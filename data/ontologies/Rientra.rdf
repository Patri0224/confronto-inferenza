  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#d3551"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#d355"/>
  <ICF-:description xml:lang="en">Initiating, maintaining, shaping or terminating an argument or debate with more than one individual.</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Discussion with many people</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d3558">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#d355"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Discussion, other specified</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d360">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Activities_and_participation"/>
