  <rdf:type rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Hand_Conditions"/>
  <ICF-:description xml:lang="en">Lifting or taking up a small object with hands and fingers, such as when picking up a pencil.</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Picking up</rdfs:label>
