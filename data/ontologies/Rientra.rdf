  <rdf:type rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Hearing_Loss"/>
  <ICF-:description xml:lang="en">Engaging in any form of simple economic transaction, such as using money to purchase food or bartering, exchanging goods or services; or saving money.</ICF-:description>
  <ICF-:descrizioneITA rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Impegnarsi in ogni forma di transazione economica semplice, come usare denaro per comprare del cibo o usare il baratto, scambiarsi beni o servizi, o risparmiare denaro.</ICF-:descrizioneITA>
  <ICF-:nomeIta rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Transazioni economiche semplici</ICF-:nomeIta>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Basic economic transactions</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d865">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Activities_and_participation"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#d865"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Activities_and_participation"/>
  <ICF-:description xml:lang="en">Engaging in any form of complex economic transaction that involves the exchange of capital or property, and the creation of profit or economic value, such as buying a business, factory, or equipment, maintaining a bank account, or trading in commodities.</ICF-:description>
  <ICF-:descrizioneITA rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Impegnarsi in ogni forma di transazione economica complessa che implichi lo scambio di capitale o proprietÃƒ  e la creazione di profitto o valore economico, come acquistare unÃ¢â‚¬â„¢impresa, una fabbrica o apparecchiature, mantenere un conto in banca, commerciare in titoli.</ICF-:descrizioneITA>
  <ICF-:nomeIta rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Transazioni economiche complesse</ICF-:nomeIta>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Complex economic transactions</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d870">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Activities_and_participation"/>
