  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#d3302"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#d330"/>
  <ICF-:description xml:lang="en">Using words to produce complex spoken messages (complete sentences) such as giving an explanation or asking for directions.</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Producing complex spoken messages</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d335">
