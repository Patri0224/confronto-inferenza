  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Body_functions"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Spinal_Cord_Injury"/>
