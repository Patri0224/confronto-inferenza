<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#b167">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Body_functions"/>
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Stroke"/>
