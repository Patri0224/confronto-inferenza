  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Spinal_Cord_Injury"/>
  <ICF-:description xml:lang="en">Getting into and out of a lying down position or changing body position, from horizontal to any other position, such as standing up or sitting down.

Inclusions: getting into a prostrate position</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lying down</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d4102">
