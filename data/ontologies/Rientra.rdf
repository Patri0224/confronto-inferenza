  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#d410"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Spinal_Cord_Injury"/>
  <ICF-:description xml:lang="en">Getting into and out of a standing position or changing body position from standing to any other position, such as lying down or sitting down.</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Standing</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d4105">
