  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Spinal_Cord_Injury"/>
  <ICF-:description xml:lang="en">Getting into and out of a position where the body is supported by the knees with legs bent, such as during prayers, or changing body position from kneeling to any other position, such as standing up.</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kneeling</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d4103">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Spinal_Cord_Injury"/>
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#d410"/>
