</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/RientraOnt3Merged#b2700">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#b270"/>
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Hand_Conditions"/>
  <ICF-:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sensory functions of sensing cold and heat.</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sensitivity to temperature</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/RientraOnt3Merged#b2701">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#b270"/>
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Hand_Conditions"/>
  <ICF-:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sensory functions of sensing shaking or oscillation.</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sensitivity to vibration</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/RientraOnt3Merged#b2702">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#b270"/>
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Hand_Conditions"/>
  <ICF-:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sensory functions of sensing pressure against or on the skin.
Inclusions: sensitivity to touch, numbness, hypaesthesia, hyperaesthesia, paraesethesia, tingling</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sensitivity to pressure</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/RientraOnt3Merged#b2703">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#b270"/>
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Hand_Conditions"/>
  <ICF-:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sensory functions of sensing painful or uncomfortable sensations.
Inclusions: impairments such as hypalgesia, hyperpathia, allodynia, analgesia and anaesthesia dolorosa</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sensitivity to a noxious stimulus</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/RientraOnt3Merged#b435">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Body_functions"/>
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Muskoloskeletal_Conditions_for_Post_Acute_Care"/>
  <ICF-:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Functions of the body related to protection against foreign substances, including infections, by specific and non-specific immune responses.  
Inclusions: immune response (specific and non-specific); hypersensitivity reactions; functions of lymphatic vessels and nodes; functions of cell-mediated immunity, antibody-mediated immunity; response to immunization; impairments such as in autoimmunity, allergic reactions, lymphadenitis and lymphoedema</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Immunological system functions</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/RientraOnt3Merged#b7100">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#b710"/>
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Hand_Conditions"/>
  <ICF-:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Functions of the range and ease of movement of one joint.</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mobility of a single joint</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/RientraOnt3Merged#b7101">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#b710"/>
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Hand_Conditions"/>
  <ICF-:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Functions of the range and ease of movement of more than one joint.</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mobility of several joints</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/RientraOnt3Merged#b7300">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#b730"/>
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Hand_Conditions"/>
  <ICF-:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Functions related to the force generated by the contraction of specific and isolated muscles and muscle groups.
Inclusions: impairments such as weakness of small muscles of feet or hands</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Power of isolated muscles and muscle groups</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/RientraOnt3Merged#b7301">
