  <ICF-:description xml:lang="en">Using fingers and hands to exert control over, direct or guide something, such as when handling coins or other small objects, such as scissors, shoe laces, pencils, chopsticks, knives and forks.</ICF-:description>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Manipulating</rdfs:label>
</owl:Class>

