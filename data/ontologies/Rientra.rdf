  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Spinal_Cord_Injury"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Stroke"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Traumatic_Brain_Injury"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Vocational_Rehabilitation"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Hand_Conditions"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Hearing_Loss"/>
  <ICF-:description xml:lang="en">Using devices, techniques and other means for the purposes of communicating, such as calling a friend on the telephone.

Inclusions: using telecommunication devices, using writing machines and communication techniques</ICF-:description>
  <ICF-:descrizioneITA rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Utilizzare strumenti, tecniche e altri mezzi per scopi comunicativi, come chiamare un amico al telefono.

Inclusioni: utilizzare strumenti di telecomunicazione, usare macchine per scrivere e tecniche di comunicazione</ICF-:descrizioneITA>
  <ICF-:nomeIta rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Utilizzo di strumenti e tecniche di comunicazione</ICF-:nomeIta>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Using communication devices and techniques</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d398">
