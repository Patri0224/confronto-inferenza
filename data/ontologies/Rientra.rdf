  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Stroke"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Traumatic_Brain_Injury"/>
  <ICF-:description xml:lang="en">Using gestures, symbols and drawings to convey messages, such as shaking one's head to indicate disagreement or drawing a picture or diagram to convey a fact or complex idea.

Inclusions: producing body gestures, signs, symbols, drawings and photographs</ICF-:description>
  <ICF-:descrizioneITA rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Usare segni, simboli e disegni per comunicare significati, come scuotere la testa per indicare disaccordo o disegnare unÃ¢â‚¬â„¢immagine o un grafico per comunicare un fatto o unÃ¢â‚¬â„¢idea complessa.

Inclusioni: produrre gesti con il corpo, segni, simboli, disegni e fotografie</ICF-:descrizioneITA>
  <ICF-:nomeIta rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Produrre messaggi non verbali</ICF-:nomeIta>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Producing nonverbal messages</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d345">
