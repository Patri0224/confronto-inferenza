</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#b1646">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#b164"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
