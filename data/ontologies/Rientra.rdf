<owl:ObjectProperty rdf:about="http://www.stiima.cnr.it/RientraHC#isInHealthCondition">
  <rdfs:domain rdf:resource="http://www.stiima.cnr.it/FOAF-excerpt#Person"/>
  <rdfs:range rdf:resource="http://www.stiima.cnr.it/RientraHC#Health_Condition"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.stiima.cnr.it/RientraOnt3#hasExtremeCriticalityIn">
  <owl:inverseOf rdf:resource="http://www.stiima.cnr.it/RientraOnt3#isExtremelyCriticalFor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.stiima.cnr.it/RientraOnt3#isExtremelyCriticalFor">
  <rdfs:domain rdf:resource="http://www.stiima.cnr.it/SkAb#Abilities"/>
  <rdfs:domain rdf:resource="http://www.stiima.cnr.it/SkAb#Skills"/>
  <rdfs:range rdf:resource="http://www.stiima.cnr.it/FOAF-excerpt#Person"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Describe which O*NET-SOC Skill or Ability is extremely critical for a person being evaluated in a specific profession.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.stiima.cnr.it/RientraOnt3#hasMatch">
