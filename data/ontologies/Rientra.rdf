  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Activities_and_participation"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Spinal_Cord_Injury"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Stroke"/>
  <rdf:type rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Traumatic_Brain_Injury"/>
  <ICF-:description xml:lang="en">Producing the literal and implied meanings of messages that are conveyed through written language, such as writing a letter to a friend.</ICF-:description>
  <ICF-:descrizioneITA rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Produrre il significato letterale e implicito di messaggi che vengono comunicati tramite il linguaggio scritto, come scrivere una lettera a un amico.</ICF-:descrizioneITA>
  <ICF-:nomeIta rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Scrivere messaggi</ICF-:nomeIta>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Writing messages</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d350">
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Activities_and_participation"/>
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Stroke"/>
  <rdfs:subClassOf rdf:resource="http://www.stiima.cnr.it/ICF-exc-coreset#Traumatic_Brain_Injury"/>
