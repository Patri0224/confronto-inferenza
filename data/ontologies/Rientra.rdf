  <rdf:type rdf:resource="http://www.stiima.cnr.it/RientraOnt3Merged#Hearing_Loss"/>
  <ICF-:description xml:lang="en">Producing words, phrases and longer passages in spoken messages with literal and implied meaning, such as expressing a fact or telling a story in oral language.</ICF-:description>
  <ICF-:descrizioneITA rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Produrre parole, frasi e brani piÃƒÂ¹ lunghi allÃ¢â‚¬â„¢interno di messaggi verbali con significato letterale e implicito, come esporre un fatto o raccontare una storia attraverso il linguaggio verbale.</ICF-:descrizioneITA>
  <ICF-:nomeIta rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parlare</ICF-:nomeIta>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Speaking</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.stiima.cnr.it/ICF-exc-coreset#d3300">
